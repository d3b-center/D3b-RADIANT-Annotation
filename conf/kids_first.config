process {
    withName: BCFTOOLS_STRIP {
        container = 'staphb/bcftools:1.23.1'
        ext.prefix = "${params.output_basename}.stripped"
        ext.args = {[
            (params.rm_fields_csv) ? "-x ${params.rm_fields_csv}" : '',
            (params.annot_fields_csv) ? "-c ${params.annot_fields_csv}" : '',
            (params.bcftools_strip_extra_args) ? "${params.bcftools_strip_extra_args.join(' ')}" : ''
        ].join (' ').strip()
        }
    }
    withName: BCFTOOLS_NORM {
        container = 'staphb/bcftools:1.23.1'
        ext.prefix = "${params.output_basename}.norm"
        ext.args = {[
            (params.check_ref) ? "-c ${params.check_ref}" : '',
            (params.multiallelics) ? "-m ${params.multiallelics}" : '',
        ].join (' ').trim()
        }
    }
    withName: ENSEMBLVEP_VEP {
        container = 'ensemblorg/ensembl-vep:release_105.0'
        ext.args =  {[
            "--canonical",
            "--format vcf",
            "--hgvs",
            "--hgvsg",
            "--no_stats",
            "--numbers",
            "--offline",
            "--fields Allele,Consequence,IMPACT,SYMBOL,Feature_type,Gene,PICK,Feature,EXON,BIOTYPE,INTRON,HGVSc,HGVSp,STRAND,CDS_position,cDNA_position,Protein_position,Amino_acids,Codons,VARIANT_CLASS,HGVSg,CANONICAL,RefSeq,MANE,MANE_SELECT,MANE_PLUS",
            "--flag_pick",
            "--mane",
            "--mane_select",
            "--pick_order rank,biotype,mane_select,mane_plus_clinical,canonical,appris,tsl,ccds,length,ensembl,refseq",
            "--symbol",
            "--variant_class",
            "--vcf",
            "--xref_refseq",
            params.vep_buffer_size ? "--buffer_size ${params.vep_buffer_size}" : ''
        ].join (' ').trim()
        }
        ext.prefix =  "${params.output_basename}"
        publishDir = [
                mode: 'copy',
                path: { "${params.outdir}/ENSEMBLVEP_VEP/" },
                pattern: "*vcf.gz*"
        ]
    }
    withName: ECHTVAR_ANNO {
        container = 'pgc-images.sbgenomics.com/d3b-bixu/echtvar:0.2.0'
        ext.prefix =  "${params.output_basename}"
        publishDir = [
                mode: 'copy',
                path: { "${params.outdir}/ECHTVAR/" },
                pattern: "*vcf.gz*"
        ]
    withName: SLIVAR_COMPOUND_HETS {
        container = 'brentp/slivar:v0.3.1'
        ext.prefix =  "${params.output_basename}.compound_hets"
        publishDir = [
                mode: 'copy',
                path: { "${params.outdir}/SLIVAR/" },
                pattern: "*vcf.gz*"
        ]
    withName: EXOMISER {
        container = 'ferlabcrsj/exomiser:2.4.1'
        ext.args = { "--output-filename=${params.output_basename}.exomiser" }
        }
        publishDir = [
                mode: 'copy',
                path: { "${params.outdir}/EXOMISER/" },
                pattern: "*exomiser*"
        ]
}

